<!DOCTYPE html>
<html lang="en">
<%- include("./partials/head.ejs") %>

<body>
  <%- include("./partials/nav.ejs") %>

  <div class="details content" style="max-width:900px; margin:50px auto; padding:30px; background:#f9f9f9; border-radius:12px; box-shadow:0 6px 15px rgba(0,0,0,0.1); font-family:Arial, sans-serif; line-height:1.7;">
    
    <h1 style="color:#007BFF; text-align:center; margin-bottom:25px;"><%= blog.title %></h1>
    
    <div class="content" style="color:#555; font-size:1.1em;">
      <%- blog.body %> <!-- Use <%- %> to render HTML properly -->
    </div>
    
    <div style="text-align:right; margin-top:30px;">
      <a class="delete" data-doc="<%= blog._id %>" style="display:inline-block; padding:10px 15px; background:#FF4C4C; color:#fff; border-radius:8px; text-decoration:none; font-weight:bold; transition:background 0.3s;">
        <img src="/trashcan.svg" alt="Delete Icon" style="width:18px; vertical-align:middle; margin-right:5px;">
        Delete Blog
      </a>
    </div>
  </div>

  <%- include("./partials/footer.ejs") %>

  <script>
    const trashcan = document.querySelector('a.delete');

    if (trashcan) {
      trashcan.addEventListener('click', (e) => {
        e.preventDefault();
        const endpoint = `/blogs/${trashcan.dataset.doc}`;

        fetch(endpoint, {
          method: 'DELETE',
        })
        .then(response => response.json())
        .then(data => window.location.href = data.redirect)
        .catch(err => console.log(err));
      });

      // Hover effect for delete button
      trashcan.addEventListener('mouseover', () => trashcan.style.background = '#CC0000');
      trashcan.addEventListener('mouseout', () => trashcan.style.background = '#FF4C4C');
    }
  </script>
</body>
</html>